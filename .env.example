# =============================================================================
# .env.example — copie para .env e preencha. O .env real NAO vai pro Git.
# =============================================================================

# ---- MinIO (object storage S3) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ---- Acesso S3 do pipeline (iguais as credenciais do MinIO acima) ----
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1

# ---- Airflow ----
AIRFLOW_UID=50000
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
